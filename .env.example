# Optional public runtime overrides
EXPO_PUBLIC_GATEWAY_ORIGIN=https://gateway.example.invalid
EXPO_PUBLIC_MARKET_ORIGIN=https://market.example.invalid
EXPO_PUBLIC_PUSH_ORIGIN=wss://push.example.invalid
EXPO_PUBLIC_SITE_ORIGIN=https://site.example.invalid
EXPO_PUBLIC_FILE_ORIGIN=https://files.example.invalid
EXPO_PUBLIC_MARKET_HOST=market.example.invalid
EXPO_PUBLIC_CHAIN_HOST=gateway.example.invalid
EXPO_PUBLIC_FILE_HOST=files.example.invalid
EXPO_PUBLIC_CHAIN_ORIGIN=https://gateway.example.invalid

# Optional BLE/device settings
EXPO_PUBLIC_BLE_SERVICE_UUID=6E400001-B5A3-F393-E0A9-E50E24DCCA9E
EXPO_PUBLIC_BLE_WRITE_CHARACTERISTIC_UUID=6E400002-B5A3-F393-E0A9-E50E24DCCA9E
EXPO_PUBLIC_BLE_NOTIFY_CHARACTERISTIC_UUID=6E400003-B5A3-F393-E0A9-E50E24DCCA9E
EXPO_PUBLIC_DEVICE_AUTH_KEY=0x1234,0x1234,0x1234,0x1234

# Client-side integration values. These are bundled into the app at build time.
# Despite legacy names like SECRET and TOKEN, do not treat EXPO_PUBLIC_* values as confidential server secrets.
# Keep real backend-only secrets on your server, not in the mobile app.
EXPO_PUBLIC_CHAIN_APP_KEY=
EXPO_PUBLIC_CHAIN_APP_SECRET=
EXPO_PUBLIC_FIRMWARE_MD5_BASE=https://gateway.example.invalid/api/r2/app/md5?key=lvgl
EXPO_PUBLIC_FIRMWARE_MD5_HEADER_NAME=x-app-token
EXPO_PUBLIC_FIRMWARE_MD5_TOKEN=
EXPO_PUBLIC_SUPPORT_EMAIL=support@lukkey.com
