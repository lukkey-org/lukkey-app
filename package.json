{
  "name": "lukkey-app",
  "version": "0.0.7",
  "scripts": {
    "Step1_installlegacy": "yarn install",
    "Step2_prebuild": "cross-env LANG=en_US.UTF-8 npx expo prebuild --clean",
    "Step3_podinstall": "cd ios && cross-env LANG=en_US.UTF-8 pod install && cd ..",
    "Step4.1_ios": "expo run:ios",
    "Step4.2_android": "expo run:android",
    "Step5_add_cross_env": "yarn add cross-env --dev",
    "dev": "cross-env REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0) NODE_ENV=development expo start --dev-client --host lan",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "build:ios:production": "npx eas-cli build --profile production --platform ios",
    "build:ios:adhoc": "npx eas-cli build --profile adhoc --platform ios",
    "build:ios:development": "npx eas-cli build --profile development --platform ios --clear-cache",
    "build:android:development": "npx eas-cli build --profile development --platform android",
    "getIosAppStore": "npx eas-cli build --platform ios --profile production --auto-submit",
    "registerDevice": "npx eas-cli device:create",
    "buildApk": "npx eas-cli build -p android --profile apk",
    "getAab": "npx eas-cli build --profile production --platform android --clear-cache",
    "pushPlayStore": "npx eas-cli build --auto-submit --platform android",
    "DownloadKeystore": "npx eas-cli credentials --platform android",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@getquip/expo-nordic-dfu": "^3.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.2",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/elements": "^1.3.31",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@types/react": "~19.1.10",
    "base64-js": "^1.5.1",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.7",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "~17.0.8",
    "expo-navigation-bar": "~5.0.10",
    "expo-notifications": "~0.32.16",
    "expo-screen-capture": "~8.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "i18next": "^23.11.5",
    "intl-pluralrules": "^2.0.1",
    "metro": "0.83.3",
    "metro-cache": "^0.80.9",
    "metro-config": "0.83.3",
    "metro-resolver": "0.83.3",
    "nativewind": "^2.0.11",
    "patch-package": "^8.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^14.1.2",
    "react-native": "^0.81.0",
    "react-native-ble-plx": "^3.5.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-colors": "1.2.6",
    "react-native-qrcode-svg": "^6.3.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "text-encoding": "^0.7.0",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native-community/cli": "^20.0.2",
    "@react-native-community/cli-platform-ios": "^18.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "cross-env": "7.0.3",
    "expo-build-properties": "~1.0.10",
    "jest": "~29.7.0",
    "tailwindcss": "3.3.2"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "resolutions": {
    "baseline-browser-mapping": "2.10.0"
  },
  "private": true,
  "packageManager": "yarn@1.22.19"
}
